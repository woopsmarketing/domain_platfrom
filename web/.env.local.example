# ============================================================
# Supabase
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Settings → Database → Connection string → URI (Transaction mode port 6543)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# ============================================================
# RapidAPI (domain-metrics-check)
# https://rapidapi.com/domain-metrics-check
RAPIDAPI_KEY=

# ============================================================
# WhoisXML API
# https://www.whoisxmlapi.com/
WHOIS_API_KEY=

# ============================================================
# Upstash Redis (optional - 캐시 없이도 동작함)
# https://console.upstash.com/
REDIS_URL=
REDIS_TOKEN=
